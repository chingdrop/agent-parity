# Copy to .env and fill in values. Everything is optional for the demo path:
# unset vendor credentials put the connector into fixture mode (sample_data/).
# .env is gitignored; config.yaml (committed) references these via ${VAR}.

# --- SentinelOne (global scope: named accounts, shared by whichever clients -
# --- use each one) ------------------------------------------------------------
# Two genuinely separate consoles in practice: "mssp" for ordinary
# managed-services clients, "dfir" for clients under active incident
# response — see config.yaml's accounts: block.
SENTINELONE_MSSP_API_URL=
SENTINELONE_MSSP_API_TOKEN=
SENTINELONE_DFIR_API_URL=
SENTINELONE_DFIR_API_TOKEN=

# --- BitDefender GravityZone (global scope, one "default" account today) -----
BITDEFENDER_API_URL=
BITDEFENDER_API_KEY=

# --- Carbon Black Cloud (per-client scope: one credential set per client) ----
ACME_CB_API_URL=
ACME_CB_API_ID=
ACME_CB_API_KEY=
ACME_CB_ORG_KEY=
# Acme's second Carbon Black tenant (a separate org, e.g. a branch office) —
# multiple tenants per client are supported by just repeating this same
# per-client credential shape; see config.yaml's "label: branch" entry.
ACME_CB2_API_URL=
ACME_CB2_API_ID=
ACME_CB2_API_KEY=
ACME_CB2_ORG_KEY=

# --- Object storage (AD-export handoff; MinIO in Docker Compose, real S3 ----
# --- in production — same code, just different endpoint_url/creds) ----------
# Required for a live vendor connector — the vendor's own remote-execution
# output channel doesn't reliably preserve the exported CSV's formatting.
# Only safe to leave unset in the uv demo path, which has no live vendor
# credentials either (no script ever actually runs).
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_BUCKET=agent-parity-ad-exports
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1

# --- MinIO server itself (docker/docker-compose.yml only) ---------------------
# Should match STORAGE_ACCESS_KEY/STORAGE_SECRET_KEY above.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- Splunk HEC (optional coverage-delta forwarding) --------------------------
# Unset by default (disabled) — see agent_parity/reporting/splunk_export.py.
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
