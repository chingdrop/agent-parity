# Copy to .env and fill in values. Everything is optional for the demo path:
# unset vendor credentials put connectors into fixture mode (sample_data/).
# .env is gitignored; config.yaml (committed) references these via ${VAR}.

# --- Django / infrastructure -------------------------------------------------
SECRET_KEY=
# Unset -> SQLite at the repo root (demo mode). The Docker stack sets this
# to the compose Postgres service.
DATABASE_URL=
# Celery broker + result backend (only needed in scaled mode).
REDIS_URL=
# Comma-separated, production only.
ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=

# --- SentinelOne (global scope: one token for the whole org) -----------------
SENTINELONE_API_URL=
SENTINELONE_API_TOKEN=

# --- BitDefender GravityZone (global scope) ----------------------------------
BITDEFENDER_API_URL=
BITDEFENDER_API_KEY=

# --- Carbon Black Cloud (per-client scope: one credential set per client) ----
ACME_CB_API_URL=
ACME_CB_API_ID=
ACME_CB_API_KEY=
ACME_CB_ORG_KEY=

# --- Splunk HEC (optional delta forwarding) -----------------------------------
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# --- Object storage (AD-export handoff; MinIO in Docker Compose, real S3 ----
# --- in production — same code, just different endpoint_url/creds) ----------
# Required for any client with live vendor credentials — the vendor's own
# remote-execution output channel doesn't reliably preserve the exported
# CSV's formatting. Only safe to leave unset in the uv demo path, which has
# no live vendor credentials either (no script ever actually runs).
STORAGE_ENDPOINT_URL=http://minio:9000
STORAGE_BUCKET=agent-parity-ad-exports
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1

# --- MinIO server itself (Docker Compose only) --------------------------------
# Should match STORAGE_ACCESS_KEY/STORAGE_SECRET_KEY above.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- Docker Compose Postgres --------------------------------------------------
POSTGRES_DB=agent_parity
POSTGRES_USER=agent_parity
POSTGRES_PASSWORD=
