# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/

# CLI output
output/
*.log

# `sync` subcommand's default run-history store (see agent_parity/db.py) —
# AGENT_PARITY_DB_URL points elsewhere for anything that isn't local/demo.
agent_parity.db
*.db

# Secrets — config.yaml holds only ${VAR} references and is safe to commit;
# .env holds the actual values and must never be.
.env
.env.*
!.env.example

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.claude/
.idea/
.vscode/
.DS_Store
